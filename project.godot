; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="4-asteroids"
run/main_scene="uid://bieyy1rehxo43"
run/print_header=false
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps=60
config/icon="uid://bbxnibplqqfmd"

[audio]

driver/output_latency.web=75

[autoload]

GameController="*uid://dmx416vjay6xm"
SaveManager="*uid://51pnuxxtennp"
Signals="*uid://32t5dfo3gom1"

[debug]

gdscript/warnings/unused_signal=0
gdscript/warnings/untyped_declaration=1
gdscript/warnings/unsafe_property_access=1

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/project_doctor_mini/plugin.cfg", "res://addons/script-ide/plugin.cfg", "res://addons/simple_gdscript_formatter/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "teal",
"res://autoload/": "pink",
"res://debug/": "red",
"res://reports/": "red",
"res://resources/": "purple",
"res://scenes/": "yellow",
"res://scripts/": "orange",
"res://shaders/": "blue"
}

