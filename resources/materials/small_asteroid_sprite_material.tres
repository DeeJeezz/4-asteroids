[gd_resource type="ShaderMaterial" format=3 uid="uid://djoe8rwl2pkng"]

[sub_resource type="Shader" id="Shader_qtwam"]
code = "shader_type canvas_item;

render_mode unshaded;

uniform bool use_cracks = false;
uniform bool use_hit_flash = false;
uniform bool use_iframes_flash = false;

group_uniforms CrackSettings;
uniform vec4 crack_color : source_color = vec4(0.05, 0.04, 0.03, 1.0);
uniform float crack_amount : hint_range(0.0, 1.0) = 1.0;
uniform float crack_scale : hint_range(2.0, 80.0) = 12.0;
uniform float crack_thickness : hint_range(0.001, 0.08) = 0.025;
uniform float crack_opacity : hint_range(0.0, 1.0) = 1.0;
uniform float crack_pixel_snap : hint_range(1.0, 16.0) = 16.0;
uniform float crack_seed = 0.0;
group_uniforms;

group_uniforms HitFlashSettings;
uniform vec4 hit_flash_color: source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float hit_flash_amount: hint_range(0.0, 1.0) = 0.0;
group_uniforms;

group_uniforms IframesSettings;
uniform vec4 iframes_color: source_color = vec4(1.0, 1.0, 1.0, 0.5);
uniform float iframes_speed: hint_range(0.0, 24.0, 0.1) = 16.0;
group_uniforms;


// Region Cracks.
float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7)) + crack_seed) * 43758.5453123);
}

vec2 hash2(vec2 p) {
	return fract(sin(vec2(
		dot(p, vec2(127.1, 311.7)),
		dot(p, vec2(269.5, 183.3))
	) + crack_seed) * 43758.5453);
}

float line_distance(vec2 p, vec2 a, vec2 b) {
	vec2 pa = p - a;
	vec2 ba = b - a;
	float h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
	return length(pa - ba * h);
}

float crack_pattern(vec2 uv) {
	vec2 p = uv * crack_scale;

	if (crack_pixel_snap > 1.0) {
		p = floor(p * crack_pixel_snap) / crack_pixel_snap;
	}

	vec2 cell = floor(p);
	vec2 local = fract(p);

	float result = 0.0;

	for (int y = -1; y <= 1; y++) {
		for (int x = -1; x <= 1; x++) {
			vec2 offset = vec2(float(x), float(y));
			vec2 c = cell + offset;

			float rnd = hash(c);

			if (rnd < crack_amount) {
				vec2 start_point = hash2(c);
				vec2 dir = normalize(hash2(c + 13.37) - 0.5);

				float len = mix(0.25, 1.2, hash(c + 21.0));
				vec2 end_point = start_point + dir * len;

				vec2 current_pos = local - offset;

				float d = line_distance(current_pos, start_point, end_point);

				float crack = 1.0 - smoothstep(
					crack_thickness,
					crack_thickness * 1.8,
					d
				);

				result = max(result, crack);
			}
		}
	}

	return result;
}
// Endregion Cracks.

void fragment() {
	vec4 base = texture(TEXTURE, UV);
	vec4 final_color = base;

	// Applying cracks.
	if (use_cracks) {
		float cracks = crack_pattern(UV);
		final_color.rgb = mix(
			base.rgb,
			crack_color.rgb,
			cracks * crack_opacity * crack_color.a
		);
		final_color.a = base.a;
	}
	// Applying hit_flash effect.
	if (use_hit_flash) {
		final_color.rgb = mix(
			final_color.rgb,
			hit_flash_color.rgb,
			hit_flash_amount * hit_flash_color.a
		);
	}
	// Applying iframes effect.
	if (use_iframes_flash) {
		final_color.a = mix(
			final_color.a,
			final_color.a * iframes_color.a,
			abs(sin(TIME * iframes_speed))
		);
	}
	
	COLOR = final_color;
}"

[resource]
shader = SubResource("Shader_qtwam")
shader_parameter/use_cracks = true
shader_parameter/use_hit_flash = false
shader_parameter/use_iframes_flash = false
shader_parameter/crack_color = Color(0.49137908, 0.055082887, 4.813075e-08, 1)
shader_parameter/crack_amount = 0.0
shader_parameter/crack_scale = 72.000003325
shader_parameter/crack_thickness = 0.048000002279999995
shader_parameter/crack_opacity = 1.0
shader_parameter/crack_pixel_snap = 16.0
shader_parameter/crack_seed = 456456.0
shader_parameter/hit_flash_color = Color(1, 1, 1, 1)
shader_parameter/hit_flash_amount = 0.0
shader_parameter/iframes_color = Color(1, 1, 1, 0.5)
shader_parameter/iframes_speed = 16.0
